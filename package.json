{
  "name": "email-worker",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "node scripts/ensure-husky.mjs && wrangler dev",
    "test": "node scripts/ensure-husky.mjs && vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "yarn oxlint --deny-warnings --report-unused-disable-directives",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "setup:hooks": "node scripts/ensure-husky.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.@(ts|tsx|mts|js|jsx|mjs|cjs)": [
      "oxlint --fix --quiet",
      "oxfmt --write"
    ],
    "*.@(json|jsonc|json5|md|mdx|yaml|yml|css|scss|sass|html|toml)": "oxfmt --write",
    ".github/workflows/*.@(yml|yaml)": "actionlint"
  },
  "dependencies": {
    "letterparser": "^0.1.5"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.0",
    "@cloudflare/workers-types": "^4.20240502.0",
    "@typescript/native-preview": "^7.0.0-dev.20260505.1",
    "@vitest/coverage-istanbul": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "husky": "9",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.63.0",
    "typescript": "^5.4.5",
    "vitest": "^4"
  },
  "packageManager": "yarn@4.16.0",
  "dependenciesMeta": {
    "esbuild": {
      "built": true
    },
    "workerd": {
      "built": true
    }
  }
}
